NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/imam-ahmad-academy

# Frontend origin (CORS whitelist — never use * in production)
CLIENT_URL=http://localhost:5173

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_secret_for_access_tokens_xxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=replace_with_64_char_random_secret_for_refresh_tokens_xxxxxxxxxxxxxxxx

# Email verification (OTP) — required in production for real delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="الموقع الرسمي للشيخ شعبان العودة <your_email@gmail.com>"

# Public contact inbox (receives contact-form emails; falls back to site settings footer.email)
CONTACT_EMAIL=shbanalwdt48@gmail.com

